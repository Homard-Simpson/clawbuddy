{
    "manufacturer": "waveshare",
    "target": "esp32s3",
    "builds": [
        {
            "name": "esp32-s3-touch-amoled-1.8-clawbuddy",
            "sdkconfig_append": [
                "CONFIG_LANGUAGE_EN_US=y",
                "CONFIG_LANGUAGE_ZH_CN=n",
                "CONFIG_WAKE_WORD_DISABLED=y",
                "CONFIG_USE_AFE_WAKE_WORD=n",
                "CONFIG_USE_CUSTOM_WAKE_WORD=n",
                "CONFIG_USE_AUDIO_PROCESSOR=n",
                "CONFIG_USE_DEFAULT_MESSAGE_STYLE=y",
                "CONFIG_USE_WECHAT_MESSAGE_STYLE=n",
                "CONFIG_OTA_URL=\"https://your-clawbuddy-host.example.com/clawbuddy/ota/\""
            ]
        }
    ]
}
