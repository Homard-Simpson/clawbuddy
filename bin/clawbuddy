#!/usr/bin/env python3
"""ClawBuddy product CLI.

Safe by default: operates on products/clawbuddy config only. Live prototype inspection is read-only and requires --live.
"""
from __future__ import annotations

import argparse
import concurrent.futures
import hashlib
import json
import os
import re
import socket
import subprocess
import sys
import time
import urllib.request
from pathlib import Path
from typing import Any
from urllib.parse import urlparse

ROOT = Path(__file__).resolve().parents[1]
VOICE_PROFILES = ROOT / "config" / "voice-profiles.json"
RUNTIME_EXAMPLE = ROOT / "config" / "runtime.example.json"
RUNTIME_LOCAL = ROOT / "config" / "runtime.local.json"
PAIRING_LOCAL = ROOT / "config" / "device-allowlist.local.json"
PAIRING_EXAMPLE = ROOT / "config" / "device-allowlist.example.json"
VISION_LOCAL = ROOT / "config" / "vision-cameras.local.json"
VISION_EXAMPLE = ROOT / "config" / "vision-cameras.example.json"
CACHE_DIR = ROOT / ".cache"
LIVE_CONFIG = Path.home() / ".openclaw/workspace/xiaozhi-bridge/xiaozhi-esp32-server/main/xiaozhi-server/data/.config.yaml"

def load_json(path: Path) -> dict[str, Any]:
    return json.loads(path.read_text())

def save_json(path: Path, data: dict[str, Any]) -> None:
    path.write_text(json.dumps(data, indent=2, sort_keys=False) + "\n")


def vision_path() -> Path:
    return VISION_LOCAL if VISION_LOCAL.exists() else VISION_EXAMPLE

def default_vision_data() -> dict[str, Any]:
    return {"schema": "clawbuddy.vision-cameras.v1", "discovery": {"enabled": True}, "cameras": []}

def load_vision(path: Path | None = None) -> dict[str, Any]:
    path = path or vision_path()
    if not path.exists():
        return default_vision_data()
    data = load_json(path)
    data.setdefault("schema", "clawbuddy.vision-cameras.v1")
    data.setdefault("discovery", {"enabled": True})
    data.setdefault("cameras", [])
    return data

def normalize_camera(rec: dict[str, Any]) -> dict[str, Any]:
    endpoint = str(rec.get("endpoint", "")).strip()
    parsed = urlparse(endpoint)
    host = parsed.hostname or ""
    ident = str(rec.get("id") or host or endpoint).strip().lower()
    ident = re.sub(r"[^a-z0-9_.:-]+", "-", ident).strip("-") or hashlib.sha1(endpoint.encode()).hexdigest()[:12]
    out = dict(rec)
    out["id"] = ident
    out.setdefault("label", ident)
    out.setdefault("enabled", True)
    out["endpoint"] = endpoint
    if endpoint and not out.get("statusEndpoint"):
        out["statusEndpoint"] = endpoint.rsplit("/", 1)[0] + "/status"
    return out

def configured_cameras(enabled_only: bool = True) -> list[dict[str, Any]]:
    cameras = [normalize_camera(c) for c in load_vision().get("cameras", []) if c.get("endpoint")]
    if enabled_only:
        cameras = [c for c in cameras if c.get("enabled", True)]
    return cameras

def http_fetch(url: str, timeout: float = 1.0, max_bytes: int = 4_000_000) -> tuple[int | None, bytes, str | None]:
    try:
        req = urllib.request.Request(url, headers={"User-Agent": "clawbuddy-vision/0.1"})
        with urllib.request.urlopen(req, timeout=timeout) as resp:  # noqa: S310 - LAN camera snapshots only
            data = resp.read(max_bytes + 1)
            if len(data) > max_bytes:
                return int(resp.status), data[:max_bytes], "too_large"
            return int(resp.status), data, None
    except Exception as exc:
        return None, b"", exc.__class__.__name__

def camera_health(camera: dict[str, Any], timeout: float = 1.0) -> dict[str, Any]:
    url = str(camera.get("statusEndpoint") or camera.get("endpoint"))
    status, body, err = http_fetch(url, timeout=timeout, max_bytes=32768)
    detail: dict[str, Any] | None = None
    if status and body:
        try:
            detail = json.loads(body.decode(errors="ignore"))
        except Exception:
            detail = None
    return {"ok": bool(status and 200 <= status < 300), "httpStatus": status, "error": err, "status": detail}

def camera_with_observed_status(camera: dict[str, Any], health: dict[str, Any]) -> dict[str, Any]:
    """Return camera config plus non-authoritative facts reported by firmware."""
    out = dict(camera)
    detail = health.get("status") if isinstance(health, dict) else None
    if isinstance(detail, dict):
        if detail.get("camera"):
            out["observedModel"] = detail.get("camera")
        if detail.get("hostname"):
            out["observedHostname"] = detail.get("hostname")
        if detail.get("sta_ip"):
            out["observedIp"] = detail.get("sta_ip")
    return out

def vision_camera_payload(timeout: float = 0.35, scan: bool = True) -> dict[str, Any]:
    rows = []
    for camera in discover_cameras(timeout=timeout, scan=scan):
        health = camera_health(camera, timeout=timeout)
        rows.append({**camera_with_observed_status(camera, health), "health": health})
    return {"path": str(vision_path()), "count": len(rows), "cameras": rows, "scenePolicy": scene_policy_text()}

def camera_subnets(cameras: list[dict[str, Any]]) -> list[str]:
    subnets: set[str] = set()
    for camera in cameras:
        host = urlparse(str(camera.get("endpoint", ""))).hostname or ""
        if re.fullmatch(r"\d+\.\d+\.\d+\.\d+", host):
            subnets.add(".".join(host.split(".")[:3]))
    return sorted(subnets)

def discover_cameras(timeout: float = 0.2, scan: bool = True) -> list[dict[str, Any]]:
    known = configured_cameras(enabled_only=False)
    found: dict[str, dict[str, Any]] = {c["endpoint"]: {**c, "source": "config"} for c in known}
    if not scan:
        return list(found.values())

    def probe(host: str) -> dict[str, Any] | None:
        endpoint = f"http://{host}/capture"
        if endpoint in found:
            return None
        status_url = f"http://{host}/status"
        status, body, _err = http_fetch(status_url, timeout=timeout, max_bytes=32768)
        if not status or not (200 <= status < 300):
            return None
        text = body.decode(errors="ignore")
        if "OpenClaw Vision" not in text and '\"ok\":true' not in text:
            return None
        label = f"OpenClaw Vision {host}"
        try:
            detail = json.loads(text)
            label = str(detail.get("camera") or detail.get("name") or label)
        except Exception:
            pass
        return normalize_camera({
            "id": f"openclaw-vision-{host.replace('.', '-')}",
            "label": label,
            "endpoint": endpoint,
            "statusEndpoint": status_url,
            "enabled": True,
            "source": "lan-scan",
            "tags": ["openclaw-vision", "discovered"],
        })

    for subnet in camera_subnets(known):
        hosts = [f"{subnet}.{host_id}" for host_id in range(1, 255)]
        with concurrent.futures.ThreadPoolExecutor(max_workers=128) as pool:
            for camera in pool.map(probe, hosts):
                if camera:
                    found[camera["endpoint"]] = camera
    return list(found.values())

def capture_camera(camera: dict[str, Any], out_dir: Path, timeout: float = 2.0) -> dict[str, Any]:
    status, body, err = http_fetch(str(camera.get("endpoint")), timeout=timeout)
    rec: dict[str, Any] = {"camera": camera, "ok": False, "httpStatus": status, "error": err}
    if not status or not (200 <= status < 300) or not body:
        return rec
    if not body.startswith(b"\xff\xd8\xff"):
        rec["error"] = "not_jpeg"
        rec["bytes"] = len(body)
        return rec
    digest = hashlib.sha1(body).hexdigest()[:12]
    safe_id = re.sub(r"[^a-zA-Z0-9_.-]+", "-", str(camera.get("id", "camera"))).strip("-") or "camera"
    path = out_dir / f"{safe_id}-{digest}.jpg"
    path.write_bytes(body)
    rec.update({"ok": True, "bytes": len(body), "sha1": digest, "path": str(path)})
    return rec

def scene_policy_text() -> str:
    return (
        "Use every successful camera image. Describe each camera separately unless multiple images are "
        "strongly likely to be different angles of the same scene; then give one combined scene description "
        "and mention the supporting camera labels. Call out unavailable cameras briefly."
    )

def capture_all_cameras(timeout: float = 2.0, scan: bool = True) -> dict[str, Any]:
    cameras = discover_cameras(timeout=min(timeout, 0.35), scan=scan)
    stamp = time.strftime("%Y%m%d-%H%M%S")
    out_dir = CACHE_DIR / "vision" / stamp
    out_dir.mkdir(parents=True, exist_ok=True)
    captures = [capture_camera(c, out_dir, timeout=timeout) for c in cameras if c.get("enabled", True)]
    bundle = {
        "schema": "clawbuddy.vision-scene-bundle.v1",
        "createdAt": stamp,
        "cameraConfig": str(vision_path()),
        "cameraCount": len(cameras),
        "captureCount": len([c for c in captures if c.get("ok")]),
        "captures": captures,
        "scenePolicy": scene_policy_text(),
    }
    save_json(out_dir / "bundle.json", bundle)
    return bundle

def default_pairing_data() -> dict[str, Any]:
    return {"schema": "clawbuddy.device-allowlist.v1", "approved": [], "pending": []}

def pairing_path() -> Path:
    return PAIRING_LOCAL if PAIRING_LOCAL.exists() else PAIRING_EXAMPLE

def load_pairing(path: Path | None = None) -> dict[str, Any]:
    path = path or pairing_path()
    if not path.exists():
        return default_pairing_data()
    data = load_json(path)
    data.setdefault("schema", "clawbuddy.device-allowlist.v1")
    data.setdefault("approved", [])
    data.setdefault("pending", [])
    return data

def save_pairing(data: dict[str, Any]) -> None:
    PAIRING_LOCAL.parent.mkdir(parents=True, exist_ok=True)
    save_json(PAIRING_LOCAL, data)

def normalize_device_id(value: str) -> str:
    value = value.strip().lower().replace("-", ":")
    compact = value.replace(":", "")
    if len(compact) == 12 and all(c in "0123456789abcdef" for c in compact):
        return ":".join(compact[i : i + 2] for i in range(0, 12, 2))
    if re.fullmatch(r"[0-9a-f]{2}(:[0-9a-f]{2}){5}", value):
        return value
    raise ValueError("device-id must be a Wi-Fi MAC address like aa:bb:cc:dd:ee:ff")

def normalize_client_id(value: str) -> str:
    value = value.strip().lower()
    if re.fullmatch(r"[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}", value):
        return value
    raise ValueError("client-id must be a UUID like 00000000-0000-4000-8000-000000000000")

def pair_record(device_id: str, client_id: str, label: str = "") -> dict[str, Any]:
    rec: dict[str, Any] = {"device_id": normalize_device_id(device_id), "client_id": normalize_client_id(client_id)}
    if label.strip():
        rec["label"] = label.strip()
    return rec

def record_key(rec: dict[str, Any]) -> tuple[str, str]:
    return (str(rec.get("device_id", "")).lower(), str(rec.get("client_id", "")).lower())

def add_pairing(device_id: str, client_id: str, label: str = "", pending: bool = False) -> dict[str, Any]:
    data = load_pairing()
    rec = pair_record(device_id, client_id, label)
    target = "pending" if pending else "approved"
    other = "approved" if pending else "pending"
    key = record_key(rec)
    data[other] = [r for r in data.get(other, []) if record_key(r) != key]
    for existing in data.get(target, []):
        if record_key(existing) == key:
            if label.strip():
                existing["label"] = label.strip()
            save_pairing(data)
            return existing
    data.setdefault(target, []).append(rec)
    save_pairing(data)
    return rec

def yaml_list_block(key: str, values: list[str], indent: int = 4) -> str:
    pad = " " * indent
    item_pad = " " * (indent + 2)
    if not values:
        return f"{pad}{key}: []"
    return f"{pad}{key}:\n" + "\n".join(f"{item_pad}- {v}" for v in values)

def pairing_snippet(data: dict[str, Any] | None = None) -> str:
    data = data or load_pairing()
    approved = data.get("approved", [])
    devices = sorted({str(r.get("device_id")) for r in approved if r.get("device_id")})
    clients = sorted({str(r.get("client_id")) for r in approved if r.get("client_id")})
    return "\n".join([
        "server:",
        "  auth:",
        "    enabled: true",
        yaml_list_block("allowed_devices", devices),
        yaml_list_block("allowed_clients", clients),
    ]) + "\n"

def pairing_status() -> dict[str, Any]:
    data = load_pairing()
    return {
        "path": str(pairing_path()),
        "localPath": str(PAIRING_LOCAL),
        "approved": data.get("approved", []),
        "pending": data.get("pending", []),
        "configSnippet": pairing_snippet(data),
        "liveMutated": False,
    }

def tcp_open(host: str, port: int, timeout: float = 1.0) -> bool:
    try:
        with socket.create_connection((host, port), timeout=timeout):
            return True
    except OSError:
        return False

def http_status(url: str, timeout: float = 2.0) -> int | None:
    try:
        req = urllib.request.Request(url, headers={"User-Agent": "clawbuddy-status/0.1"})
        with urllib.request.urlopen(req, timeout=timeout) as resp:  # noqa: S310 - local status checks
            return int(resp.status)
    except Exception:
        return None

def run_text(cmd: list[str]) -> str:
    try:
        return subprocess.run(cmd, text=True, capture_output=True, timeout=4, check=False).stdout
    except Exception:
        return ""

def parse_live_yaml_scalar(text: str, key: str) -> str | None:
    # Good enough for the known prototype config shape; avoids adding PyYAML dependency.
    m = re.search(rf"^\s*{re.escape(key)}:\s*([^#\n]+)", text, re.M)
    return m.group(1).strip().strip('"\'') if m else None

def live_config_snapshot() -> dict[str, Any]:
    out: dict[str, Any] = {"path": str(LIVE_CONFIG), "exists": LIVE_CONFIG.exists()}
    if not LIVE_CONFIG.exists():
        return out
    text = LIVE_CONFIG.read_text(errors="ignore")
    out["audio"] = {
        "sample_rate": parse_live_yaml_scalar(text, "sample_rate"),
        "frame_duration": parse_live_yaml_scalar(text, "frame_duration"),
    }
    # Limit VAD parse to the Silero-ish block by just taking known scalar names.
    out["silero"] = {
        "threshold": parse_live_yaml_scalar(text, "threshold"),
        "threshold_low": parse_live_yaml_scalar(text, "threshold_low"),
        "min_silence_duration_ms": parse_live_yaml_scalar(text, "min_silence_duration_ms"),
    }
    return out

def profile_data() -> dict[str, Any]:
    return load_json(VOICE_PROFILES)

def runtime_data() -> tuple[Path, dict[str, Any]]:
    path = RUNTIME_LOCAL if RUNTIME_LOCAL.exists() else RUNTIME_EXAMPLE
    return path, load_json(path)

def product_status(include_live: bool = False) -> dict[str, Any]:
    profiles = profile_data()
    runtime_path, runtime = runtime_data()
    selected = runtime.get("profile") or profiles.get("defaultProfile")
    planned_ports = runtime.get("ports", {})
    port_checks = {
        name: {"port": port, "occupied": tcp_open("127.0.0.1", int(port))}
        for name, port in planned_ports.items()
    }
    result: dict[str, Any] = {
        "root": str(ROOT),
        "runtimeConfig": str(runtime_path),
        "profile": selected,
        "profileValid": selected in profiles.get("profiles", {}),
        "publicExposureEnabled": bool(runtime.get("publicExposure", {}).get("enabled")),
        "pairing": {"path": str(pairing_path()), "approvedCount": len(load_pairing().get("approved", [])), "pendingCount": len(load_pairing().get("pending", []))},
        "launchAgentPrefix": runtime.get("launchAgentPrefix"),
        "plannedPorts": port_checks,
        "separationOk": runtime.get("launchAgentPrefix") == "com.openclaw.clawbuddy"
        and all(int(v.get("port", 0)) not in (8000, 8003, 8004, 8899, 10000) for v in port_checks.values()),
    }
    if include_live:
        serve = run_text(["tailscale", "serve", "status"])
        result["livePrototype"] = {
            "ports": {
                "prototypeWebsocket8000": tcp_open("127.0.0.1", 8000),
                "ota8003": tcp_open("127.0.0.1", 8003),
                "mcp8004": tcp_open("127.0.0.1", 8004),
                "bridge8899": tcp_open("127.0.0.1", 8899),
            },
            "http": {
                "serverRoot": http_status("http://127.0.0.1:8000/"),
                "ota": http_status("http://127.0.0.1:8003/xiaozhi/ota/"),
                "bridgeHealth": http_status("http://127.0.0.1:8899/health"),
            },
            "funnel10000": "Funnel on" in serve and ":10000" in serve,
            "config": live_config_snapshot(),
            "readOnly": True,
        }
    return result

def print_status(data: dict[str, Any]) -> None:
    print("ClawBuddy")
    print(f"root: {data['root']}")
    print(f"runtime: {data['runtimeConfig']}")
    print(f"profile: {data['profile']} ({'ok' if data['profileValid'] else 'INVALID'})")
    print(f"separation: {'ok' if data['separationOk'] else 'CHECK'}")
    print(f"public exposure: {'on' if data['publicExposureEnabled'] else 'off'}")
    pairing = data.get("pairing", {})
    print(f"pairing: {pairing.get('approvedCount', 0)} approved, {pairing.get('pendingCount', 0)} pending ({pairing.get('path')})")
    print("planned ports:")
    for name, check in data["plannedPorts"].items():
        state = "occupied" if check["occupied"] else "free"
        print(f"  - {name}: {check['port']} {state}")
    live = data.get("livePrototype")
    if live:
        print("live prototype bridge (read-only):")
        print("  ports: " + ", ".join(f"{k}={'ok' if v else 'down'}" for k, v in live["ports"].items()))
        print("  http: " + ", ".join(f"{k}={v}" for k, v in live["http"].items()))
        print(f"  funnel10000: {'ok' if live['funnel10000'] else 'missing'}")
        cfg = live.get("config", {})
        print(f"  audio: {cfg.get('audio')}")
        print(f"  silero: {cfg.get('silero')}")

def cmd_profiles(args: argparse.Namespace) -> int:
    data = profile_data()
    if args.json:
        print(json.dumps(data, indent=2))
        return 0
    print(f"default: {data.get('defaultProfile')}")
    for name, profile in data.get("profiles", {}).items():
        silero = profile.get("silero", {})
        print(f"- {name}: {profile.get('description')}")
        print(
            "  "
            + f"threshold={silero.get('threshold')} "
            + f"threshold_low={silero.get('threshold_low')} "
            + f"silence_ms={silero.get('min_silence_duration_ms')}"
        )
    return 0

def cmd_tune(args: argparse.Namespace) -> int:
    profiles = profile_data()
    if args.profile not in profiles.get("profiles", {}):
        print(f"Unknown profile: {args.profile}", file=sys.stderr)
        return 2
    source = RUNTIME_LOCAL if RUNTIME_LOCAL.exists() else RUNTIME_EXAMPLE
    runtime = load_json(source)
    runtime["profile"] = args.profile
    save_json(RUNTIME_LOCAL, runtime)
    if args.json:
        print(json.dumps({"updated": str(RUNTIME_LOCAL), "profile": args.profile, "liveMutated": False}, indent=2))
    else:
        print(f"Set ClawBuddy product profile to {args.profile} in {RUNTIME_LOCAL}")
        print("Live prototype bridge was not changed.")
    return 0

def cmd_pair(args: argparse.Namespace) -> int:
    if args.pair_cmd == "add":
        try:
            rec = add_pairing(args.device_id, args.client_id, args.label or "", pending=args.pending)
        except ValueError as exc:
            print(str(exc), file=sys.stderr)
            return 2
        state = "pending" if args.pending else "approved"
        if args.json:
            print(json.dumps({"state": state, "record": rec, "path": str(PAIRING_LOCAL), "liveMutated": False}, indent=2))
        else:
            print(f"Added {state} device to {PAIRING_LOCAL}")
            print(f"  device-id: {rec['device_id']}")
            print(f"  client-id: {rec['client_id']}")
            print("Live server config was not changed. Run `bin/clawbuddy pair snippet` if you need to paste config manually.")
        return 0
    if args.pair_cmd == "list":
        status = pairing_status()
        if args.json:
            print(json.dumps(status, indent=2))
        else:
            print(f"pairing file: {status['path']}")
            for section in ("approved", "pending"):
                print(f"{section}:")
                rows = status[section]
                if not rows:
                    print("  (none)")
                for rec in rows:
                    label = f"  {rec.get('label')}" if rec.get("label") else ""
                    print(f"  - device-id={rec.get('device_id')} client-id={rec.get('client_id')}{label}")
        return 0
    if args.pair_cmd == "snippet":
        print(pairing_snippet(), end="")
        return 0
    print("Choose: add, list, or snippet", file=sys.stderr)
    return 2


def cmd_vision(args: argparse.Namespace) -> int:
    if args.vision_cmd == "list":
        payload = vision_camera_payload(timeout=args.timeout, scan=not args.no_scan)
        if args.json:
            print(json.dumps(payload, indent=2))
        else:
            print(f"vision config: {payload['path']}")
            for cam in payload["cameras"]:
                health = cam.get("health", {})
                state = "ok" if health.get("ok") else f"down:{health.get('error') or health.get('httpStatus')}"
                observed = f" observed={cam['observedModel']}" if cam.get("observedModel") else ""
                print(f"- {cam.get('id')}: {cam.get('label')} {state}{observed}")
                print(f"  capture: {cam.get('endpoint')}")
        return 0
    if args.vision_cmd == "capture":
        bundle = capture_all_cameras(timeout=args.timeout, scan=not args.no_scan)
        if args.json:
            print(json.dumps(bundle, indent=2))
        else:
            print(f"captured {bundle['captureCount']}/{len(bundle['captures'])} cameras")
            for cap in bundle["captures"]:
                cam = cap.get("camera", {})
                if cap.get("ok"):
                    print(f"- {cam.get('label')}: {cap.get('path')}")
                else:
                    print(f"- {cam.get('label')}: unavailable ({cap.get('error') or cap.get('httpStatus')})")
            print("policy: " + bundle["scenePolicy"])
        return 0 if bundle["captureCount"] else 1
    if args.vision_cmd == "scene-prompt":
        print(scene_policy_text())
        return 0
    print("Choose: list, capture, or scene-prompt", file=sys.stderr)
    return 2

def cmd_status(args: argparse.Namespace) -> int:
    data = product_status(include_live=args.live)
    if args.json:
        print(json.dumps(data, indent=2))
    else:
        print_status(data)
    return 0 if data["profileValid"] and data["separationOk"] else 1

def cmd_init(args: argparse.Namespace) -> int:
    if RUNTIME_LOCAL.exists() and not args.force:
        print(f"Already exists: {RUNTIME_LOCAL}")
        return 0
    save_json(RUNTIME_LOCAL, load_json(RUNTIME_EXAMPLE))
    print(f"Created {RUNTIME_LOCAL}")
    return 0

def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="clawbuddy", description="ClawBuddy product CLI")
    sub = p.add_subparsers(dest="cmd", required=True)

    sp = sub.add_parser("status", help="Show product runtime status")
    sp.add_argument("--live", action="store_true", help="Read-only compare against a live prototype bridge")
    sp.add_argument("--json", action="store_true")
    sp.set_defaults(func=cmd_status)

    sp = sub.add_parser("profiles", help="List voice input tuning profiles")
    sp.add_argument("--json", action="store_true")
    sp.set_defaults(func=cmd_profiles)

    sp = sub.add_parser("tune", help="Set product voice input profile; does not touch a live prototype bridge")
    sp.add_argument("profile", choices=sorted(profile_data().get("profiles", {}).keys()))
    sp.add_argument("--json", action="store_true")
    sp.set_defaults(func=cmd_tune)

    sp = sub.add_parser("vision", help="List/discover OpenClaw Vision cameras and capture scene bundles")
    vision_sub = sp.add_subparsers(dest="vision_cmd", required=True)
    vision_list = vision_sub.add_parser("list", help="List configured/discovered cameras and health")
    vision_list.add_argument("--json", action="store_true")
    vision_list.add_argument("--no-scan", action="store_true", help="Only use configured cameras; do not scan configured subnets")
    vision_list.add_argument("--timeout", type=float, default=0.35)
    vision_capture = vision_sub.add_parser("capture", help="Capture snapshots from every available camera into a scene bundle")
    vision_capture.add_argument("--json", action="store_true")
    vision_capture.add_argument("--no-scan", action="store_true", help="Only use configured cameras; do not scan configured subnets")
    vision_capture.add_argument("--timeout", type=float, default=2.0)
    vision_sub.add_parser("scene-prompt", help="Print the scene-description policy for multimodal callers")
    sp.set_defaults(func=cmd_vision)

    sp = sub.add_parser("pair", help="Pair/allowlist a ClawBuddy device locally; does not mutate live services")
    pair_sub = sp.add_subparsers(dest="pair_cmd", required=True)
    pair_add = pair_sub.add_parser("add", help="Approve a device-id/client-id pair")
    pair_add.add_argument("device_id", help="Device-Id MAC address from setup page, serial logs, or OTA 403 logs")
    pair_add.add_argument("client_id", help="Client-Id UUID from setup page, serial logs, or OTA 403 logs")
    pair_add.add_argument("--label", help="Optional human label, e.g. kitchen prototype")
    pair_add.add_argument("--pending", action="store_true", help="Record as pending instead of approved")
    pair_add.add_argument("--json", action="store_true")
    pair_list = pair_sub.add_parser("list", help="Show pending/approved devices")
    pair_list.add_argument("--json", action="store_true")
    pair_sub.add_parser("snippet", help="Print a YAML server.auth allowlist snippet to paste into server config")
    sp.set_defaults(func=cmd_pair)

    sp = sub.add_parser("init", help="Create runtime.local.json from example")
    sp.add_argument("--force", action="store_true")
    sp.set_defaults(func=cmd_init)
    return p

def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)
    return int(args.func(args))

if __name__ == "__main__":
    raise SystemExit(main())
