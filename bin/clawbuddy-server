#!/usr/bin/env python3
"""Tiny ClawBuddy product status server.

This is intentionally local-only and separate from the live prototype bridge.
It exposes status JSON for a future dashboard/plugin without touching live services.
"""
from __future__ import annotations

import importlib.machinery
import importlib.util
import json
import sys
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
CLAWBUDDY_CLI = ROOT / "bin" / "clawbuddy"
loader = importlib.machinery.SourceFileLoader("clawbuddy_cli", str(CLAWBUDDY_CLI))
spec = importlib.util.spec_from_loader(loader.name, loader)
if spec is None:
    raise RuntimeError(f"Unable to load {CLAWBUDDY_CLI}")
clawbuddy = importlib.util.module_from_spec(spec)
loader.exec_module(clawbuddy)  # type: ignore[arg-type]

HOST = "127.0.0.1"
DEFAULT_PORT = 8199


class Handler(BaseHTTPRequestHandler):
    server_version = "ClawBuddyStatus/0.1"

    def log_message(self, fmt: str, *args):  # keep launchd logs quiet
        return

    def send_json(self, payload, status=200):
        body = json.dumps(payload, indent=2).encode()
        self.send_response(status)
        self.send_header("content-type", "application/json; charset=utf-8")
        self.send_header("cache-control", "no-store")
        self.send_header("content-length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self):
        if self.path in ("/", "/health"):
            self.send_json({"ok": True, "product": "ClawBuddy", "port": self.server.server_port})
            return
        if self.path == "/status":
            self.send_json(clawbuddy.product_status(include_live=False))
            return
        if self.path == "/status/live":
            self.send_json(clawbuddy.product_status(include_live=True))
            return
        if self.path == "/profiles":
            self.send_json(clawbuddy.profile_data())
            return
        self.send_json({"ok": False, "error": "not_found"}, status=404)


def main(argv=None):
    argv = argv or sys.argv[1:]
    port = int(argv[0]) if argv else DEFAULT_PORT
    server = ThreadingHTTPServer((HOST, port), Handler)
    print(f"clawbuddy status server listening on http://{HOST}:{port}", flush=True)
    server.serve_forever()


if __name__ == "__main__":
    main()
