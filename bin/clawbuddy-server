#!/usr/bin/env python3
"""Tiny myAI product status + pairing server.

This is intentionally local-only and separate from the live prototype bridge.
It exposes status JSON and a local pairing helper without touching live services.
"""
from __future__ import annotations

import html
import importlib.machinery
import importlib.util
import json
import re
import sys
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from urllib.parse import parse_qs

ROOT = Path(__file__).resolve().parents[1]
CLAWBUDDY_CLI = ROOT / "bin" / "clawbuddy"
loader = importlib.machinery.SourceFileLoader("clawbuddy_cli", str(CLAWBUDDY_CLI))
spec = importlib.util.spec_from_loader(loader.name, loader)
if spec is None:
    raise RuntimeError(f"Unable to load {CLAWBUDDY_CLI}")
clawbuddy = importlib.util.module_from_spec(spec)
loader.exec_module(clawbuddy)  # type: ignore[arg-type]

HOST = "127.0.0.1"
DEFAULT_PORT = 8199
FIRMWARE_ROOT = ROOT / "firmware" / "clawbuddy"
OTA_ROOT = FIRMWARE_ROOT / "ota"


def current_firmware_version() -> str | None:
    cmake_path = FIRMWARE_ROOT / "CMakeLists.txt"
    if not cmake_path.exists():
        return None
    match = re.search(r'set\(PROJECT_VER\s+"([^"]+)"\)', cmake_path.read_text(errors="ignore"))
    return match.group(1) if match else None


def staged_ota_binary(version: str | None = None) -> Path | None:
    version = version or current_firmware_version()
    if not version:
        return None
    candidate = OTA_ROOT / f"v{version}" / "myai.bin"
    if candidate.exists():
        return candidate
    build_candidate = FIRMWARE_ROOT / "build" / "myai.bin"
    if build_candidate.exists():
        return build_candidate
    return None


def ota_payload(base_url: str) -> dict:
    version = current_firmware_version()
    binary = staged_ota_binary(version)
    firmware = {"version": version, "url": None, "staged": False}
    if version and binary:
        firmware.update({
            "url": f"{base_url.rstrip('/')}/myai/firmware/v{version}/myai.bin",
            "staged": True,
            "bytes": binary.stat().st_size,
        })
    return {"firmware": firmware}


def pairing_html(message: str = "") -> str:
    status = clawbuddy.pairing_status()
    rows = []
    for section in ("approved", "pending"):
        items = status[section]
        if not items:
            rows.append(f"<h2>{section.title()}</h2><p class='muted'>None yet.</p>")
            continue
        lis = "".join(
            "<li><code>{device}</code><br><code>{client}</code>{label}</li>".format(
                device=html.escape(rec.get("device_id", "")),
                client=html.escape(rec.get("client_id", "")),
                label=("<br>" + html.escape(rec.get("label", ""))) if rec.get("label") else "",
            )
            for rec in items
        )
        rows.append(f"<h2>{section.title()}</h2><ul>{lis}</ul>")
    escaped_message = f"<p class='ok'>{html.escape(message)}</p>" if message else ""
    return f"""<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>myAI Pairing</title>
  <style>
    body {{ font: 16px system-ui, sans-serif; margin: 2rem; max-width: 860px; line-height: 1.45; }}
    input {{ width: 100%; box-sizing: border-box; padding: .65rem; margin: .25rem 0 1rem; font: inherit; }}
    button {{ padding: .7rem 1rem; font: inherit; cursor: pointer; }}
    code, pre {{ background: #f5f5f5; padding: .15rem .25rem; border-radius: 4px; }}
    pre {{ padding: 1rem; overflow: auto; }}
    .muted {{ color: #666; }} .ok {{ color: #146c2e; font-weight: 650; }} .warn {{ color: #8a5a00; }}
  </style>
</head>
<body>
  <h1>Pair a myAI device</h1>
  <p>This page is local-only at <code>127.0.0.1</code>. It writes a local allowlist file and never exposes pairing through Funnel.</p>
  {escaped_message}
  <form method="post" action="/pair">
    <label>Device-Id (Wi-Fi MAC)</label>
    <input name="device_id" placeholder="aa:bb:cc:dd:ee:ff" required autocomplete="off">
    <label>Client-Id (UUID)</label>
    <input name="client_id" placeholder="00000000-0000-4000-8000-000000000000" required autocomplete="off">
    <label>Label (optional)</label>
    <input name="label" placeholder="kitchen prototype" autocomplete="off">
    <button type="submit">Approve device</button>
  </form>
  {''.join(rows)}
  <h2>Server config snippet</h2>
  <p class="warn">Live server config is not mutated automatically. Paste/merge this under your server config if your runtime does not read the local allowlist file directly.</p>
  <pre>{html.escape(status['configSnippet'])}</pre>
  <p class="muted">CLI alternative: <code>bin/clawbuddy pair add &lt;device-id&gt; &lt;client-id&gt;</code></p>
</body>
</html>"""


class Handler(BaseHTTPRequestHandler):
    server_version = "myAIStatus/0.2"

    def log_message(self, fmt: str, *args):  # keep launchd logs quiet
        return

    def send_json(self, payload, status=200):
        body = json.dumps(payload, indent=2).encode()
        self.send_response(status)
        self.send_header("content-type", "application/json; charset=utf-8")
        self.send_header("cache-control", "no-store")
        self.send_header("content-length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def send_html(self, body: str, status=200):
        data = body.encode()
        self.send_response(status)
        self.send_header("content-type", "text/html; charset=utf-8")
        self.send_header("cache-control", "no-store")
        self.send_header("content-length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def send_file(self, path: Path, content_type: str = "application/octet-stream"):
        data = path.read_bytes()
        self.send_response(200)
        self.send_header("content-type", content_type)
        self.send_header("cache-control", "no-store")
        self.send_header("content-length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def base_url(self) -> str:
        host = self.headers.get("host") or f"127.0.0.1:{self.server.server_port}"
        return f"http://{host}"

    def do_GET(self):
        if self.path in ("/", "/health"):
            self.send_json({"ok": True, "product": "myAI", "port": self.server.server_port, "pairing": "/pair", "ota": "/myai/ota/"})
            return
        if self.path == "/status":
            self.send_json(clawbuddy.product_status(include_live=False))
            return
        if self.path == "/status/live":
            self.send_json(clawbuddy.product_status(include_live=True))
            return
        if self.path == "/profiles":
            self.send_json(clawbuddy.profile_data())
            return
        if self.path == "/vision/cameras":
            self.send_json(clawbuddy.vision_camera_payload(timeout=0.35, scan=True))
            return
        if self.path == "/vision/capture":
            self.send_json(clawbuddy.capture_all_cameras(timeout=2.0, scan=True))
            return
        if self.path == "/vision/policy":
            self.send_json({"scenePolicy": clawbuddy.scene_policy_text()})
            return
        if self.path == "/pair":
            self.send_html(pairing_html())
            return
        if self.path == "/pair.json":
            self.send_json(clawbuddy.pairing_status())
            return
        if self.path in ("/myai/ota", "/myai/ota/"):
            self.send_json(ota_payload(self.base_url()), status=200)
            return
        match = re.fullmatch(r"/myai/firmware/v([^/]+)/myai\.bin", self.path)
        if match:
            binary = staged_ota_binary(match.group(1))
            if binary is None:
                self.send_json({"ok": False, "error": "firmware_not_staged", "version": match.group(1)}, status=404)
                return
            self.send_file(binary)
            return
        self.send_json({"ok": False, "error": "not_found"}, status=404)

    def do_POST(self):
        if self.path in ("/myai/ota", "/myai/ota/"):
            length = int(self.headers.get("content-length", "0"))
            if length > 65536:
                self.send_json({"ok": False, "error": "request_too_large"}, status=413)
                return
            if length:
                self.rfile.read(length)
            self.send_json(ota_payload(self.base_url()), status=200)
            return
        if self.path != "/pair":
            self.send_json({"ok": False, "error": "not_found"}, status=404)
            return
        length = int(self.headers.get("content-length", "0"))
        if length > 4096:
            self.send_html(pairing_html("Form was too large."), status=400)
            return
        form = parse_qs(self.rfile.read(length).decode())
        try:
            rec = clawbuddy.add_pairing(
                form.get("device_id", [""])[0],
                form.get("client_id", [""])[0],
                form.get("label", [""])[0],
            )
        except ValueError as exc:
            self.send_html(pairing_html(str(exc)), status=400)
            return
        self.send_html(pairing_html(f"Approved {rec['device_id']} / {rec['client_id']}"))


def main(argv=None):
    argv = argv or sys.argv[1:]
    port = int(argv[0]) if argv else DEFAULT_PORT
    server = ThreadingHTTPServer((HOST, port), Handler)
    print(f"clawbuddy status server listening on http://{HOST}:{port}", flush=True)
    print(f"pairing helper: http://{HOST}:{port}/pair", flush=True)
    server.serve_forever()


if __name__ == "__main__":
    main()
